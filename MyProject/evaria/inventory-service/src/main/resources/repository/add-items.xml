<?xml version="1.0" encoding="UTF-8"?>

<add-items>
    <add-item item-descriptor="inventoryAvailability" id="IN_STOCK">
        <set-property name="displayName"><![CDATA[In Stock]]></set-property>
        <set-property name="description"><![CDATA[Item is available to sell immediately]]></set-property>
        <set-property name="available"><![CDATA[true]]></set-property>
        <set-property name="canBackorder"><![CDATA[false]]></set-property>
        <set-property name="canPreorder"><![CDATA[false]]></set-property>
    </add-item>

    <add-item item-descriptor="inventoryAvailability" id="OUT_OF_STOCK">
        <set-property name="displayName"><![CDATA[Out of Stock]]></set-property>
        <set-property name="description"><![CDATA[Item is not currently available to sell]]></set-property>
        <set-property name="available"><![CDATA[false]]></set-property>
        <set-property name="canBackorder"><![CDATA[false]]></set-property>
        <set-property name="canPreorder"><![CDATA[false]]></set-property>
    </add-item>

    <add-item item-descriptor="inventoryAvailability" id="BACKORDERABLE">
        <set-property name="displayName"><![CDATA[Backorderable]]></set-property>
        <set-property name="description"><![CDATA[Item can be sold and fulfilled later]]></set-property>
        <set-property name="available"><![CDATA[false]]></set-property>
        <set-property name="canBackorder"><![CDATA[true]]></set-property>
        <set-property name="canPreorder"><![CDATA[false]]></set-property>
    </add-item>

    <add-item item-descriptor="inventoryAvailability" id="PREORDERABLE">
        <set-property name="displayName"><![CDATA[Preorderable]]></set-property>
        <set-property name="description"><![CDATA[Item can be sold before release]]></set-property>
        <set-property name="available"><![CDATA[false]]></set-property>
        <set-property name="canBackorder"><![CDATA[false]]></set-property>
        <set-property name="canPreorder"><![CDATA[true]]></set-property>
    </add-item>

    <add-item item-descriptor="inventory" id="inv_sku1001_red_default">
        <set-property name="skuId"><![CDATA[sku1001-red]]></set-property>
        <set-property name="stockLevel"><![CDATA[25]]></set-property>
        <set-property name="availabilityStatus"><![CDATA[IN_STOCK]]></set-property>
        <set-property name="backorderLevel"><![CDATA[0]]></set-property>
        <set-property name="preorderLevel"><![CDATA[0]]></set-property>
        <set-property name="stockThreshold"><![CDATA[5]]></set-property>
        <set-property name="storeId"><![CDATA[defaultStore]]></set-property>
        <set-property name="locationId"><![CDATA[defaultWarehouse]]></set-property>
    </add-item>

    <add-item item-descriptor="inventory" id="inv_sku1001_blue_default">
        <set-property name="skuId"><![CDATA[sku1001-blue]]></set-property>
        <set-property name="stockLevel"><![CDATA[0]]></set-property>
        <set-property name="availabilityStatus"><![CDATA[BACKORDERABLE]]></set-property>
        <set-property name="backorderLevel"><![CDATA[50]]></set-property>
        <set-property name="preorderLevel"><![CDATA[0]]></set-property>
        <set-property name="stockThreshold"><![CDATA[5]]></set-property>
        <set-property name="storeId"><![CDATA[defaultStore]]></set-property>
        <set-property name="locationId"><![CDATA[defaultWarehouse]]></set-property>
    </add-item>

    <add-item item-descriptor="inventory" id="inv_sku1001_black_default">
        <set-property name="skuId"><![CDATA[sku1001-black]]></set-property>
        <set-property name="stockLevel"><![CDATA[0]]></set-property>
        <set-property name="availabilityStatus"><![CDATA[OUT_OF_STOCK]]></set-property>
        <set-property name="backorderLevel"><![CDATA[0]]></set-property>
        <set-property name="preorderLevel"><![CDATA[0]]></set-property>
        <set-property name="stockThreshold"><![CDATA[5]]></set-property>
        <set-property name="storeId"><![CDATA[defaultStore]]></set-property>
        <set-property name="locationId"><![CDATA[defaultWarehouse]]></set-property>
    </add-item>
</add-items>
