<?xml version="1.0" encoding="UTF-8"?>

<add-items>

    <!-- LIST PRICE LIST -->

    <add-item item-descriptor="priceList"
              id="listPriceList">

        <set-property name="displayName">
            Default List Price List
        </set-property>

        <set-property name="description">
            Base list pricing for all products
        </set-property>

        <set-property name="creationDate">
            2026-05-08T00:00:00
        </set-property>

        <set-property name="lastModDate">
            2026-05-08T00:00:00
        </set-property>

        <set-property name="startDate">
            2026-05-08T00:00:00
        </set-property>

        <set-property name="locale">
            en_IN
        </set-property>

    </add-item>


    <!-- SALE PRICE LIST -->

    <add-item item-descriptor="priceList"
              id="salePriceList">

        <set-property name="displayName">
            Sale Price List
        </set-property>

        <set-property name="description">
            Promotional discounted sale pricing
        </set-property>

        <set-property name="creationDate">
            2026-05-08T00:00:00
        </set-property>

        <set-property name="lastModDate">
            2026-05-08T00:00:00
        </set-property>

        <set-property name="startDate">
            2026-05-08T00:00:00
        </set-property>

        <set-property name="locale">
            en_IN
        </set-property>

        <set-property name="basePriceList">
            listPriceList
        </set-property>

    </add-item>


    <!-- REWARD PRICE LIST -->

    <add-item item-descriptor="priceList"
              id="rewardPriceList">

        <set-property name="displayName">
            Reward Member Price List
        </set-property>

        <set-property name="description">
            Exclusive reward member pricing
        </set-property>

        <set-property name="creationDate">
            2026-05-08T00:00:00
        </set-property>

        <set-property name="lastModDate">
            2026-05-08T00:00:00
        </set-property>

        <set-property name="startDate">
            2026-05-08T00:00:00
        </set-property>

        <set-property name="locale">
            en_IN
        </set-property>

        <set-property name="basePriceList">
            salePriceList
        </set-property>

    </add-item>

    <add-item item-descriptor="price" id="p_sku1001_red_sale">
        <set-property name="priceList"><![CDATA[salePriceList]]></set-property>
        <set-property name="skuId"><![CDATA[sku1001-red]]></set-property>
        <set-property name="listPrice"><![CDATA[5000.0]]></set-property>
        <set-property name="salePrice"><![CDATA[4800.0]]></set-property>
        <set-property name="currencyCode"><![CDATA[INR]]></set-property>
        <!-- Note: Sale price logic often requires a separate Sale Price List in ATG -->
    </add-item>

    <!-- Price for sku1001-blue -->
    <add-item item-descriptor="price" id="p_sku1001_blue_sale">
        <set-property name="priceList"><![CDATA[salePriceList]]></set-property>
        <set-property name="skuId"><![CDATA[sku1001-blue]]></set-property>
        <set-property name="listPrice"><![CDATA[5000.0]]></set-property>
        <set-property name="salePrice"><![CDATA[4820.0]]></set-property>
        <set-property name="currencyCode"><![CDATA[INR]]></set-property>
    </add-item>

</add-items>